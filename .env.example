# OAuthSentry Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# Day 1 (UI): NO ENV VARS NEEDED
# The dashboard and mock scan route work with zero configuration
# ============================================================================


# ============================================================================
# Day 2 (AI SDK 6 Agent): OPTIONAL
# Defaults to Vercel AI Gateway (zero-config for OpenAI, Anthropic, Google, etc.)
# Only needed if using a different AI provider
# ============================================================================
# AI_GATEWAY_API_KEY=your_key_here

# ============================================================================
# Day 3 (WDK Durable Workflow): OPTIONAL
# Defaults to localhost:3000 for dev
# Set this when deploying to production
# ============================================================================
# SCAN_API_URL=https://your-domain.vercel.app

# ============================================================================
# Day 4 (ChatSDK Slack Bot): OPTIONAL BUT RECOMMENDED FOR DEMO
# Get these from https://api.slack.com/apps after creating your Slack app
# ============================================================================
# SLACK_BOT_TOKEN=xoxb-your-token-here
# SLACK_SIGNING_SECRET=your-signing-secret-here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# Day 5 (Linear Integration): OPTIONAL BUT RECOMMENDED FOR DEMO
# SLACK_BOT_TOKEN=lin_pat_... from https://linear.app/settings/api
# LINEAR_TEAM_ID=team-... (find in Linear URL: linear.app/team/{teamId})
# If omitted, will use the first team your API key has access to
# ============================================================================
# LINEAR_API_KEY=lin_pat_your_key_here
# LINEAR_TEAM_ID=team-ABC123DEF456

# ============================================================================
# Production Only: Redis State for Chat SDK
# For development, the Chat SDK uses in-memory state (single process only)
# For production, use Redis to share state across multiple instances
# ============================================================================
# REDIS_URL=redis://default:password@host:port

# ============================================================================
# Notes
# ============================================================================
# - Day 1 (UI) works with NO env vars set
# - Day 2+ requires AI_GATEWAY_API_KEY (optional if using default models)
# - Days 4-5 require Slack/Linear setup (see README.md for links)
# - For local testing, just set SLACK_BOT_TOKEN and LINEAR_API_KEY
# - After adding/changing env vars, restart pnpm dev
